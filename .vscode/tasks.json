{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "cmake -G Ninja -B build -DCMAKE_BUILD_TYPE=Debug && ninja -C build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cmake -G Ninja -B build -DCMAKE_BUILD_TYPE=Release && ninja -C build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Format all C++ files",
      "type": "shell",
      "command": "find src -name '*.cpp' -o -name '*.hpp' | xargs clang-format -i",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Format CMakeLists.txt",
      "type": "shell",
      "command": "cmake-format -i CMakeLists.txt",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}